# Database
DATABASE_URL=postgresql://user:password@host:5432/clearfunnel

# API Server
PORT=3000
NODE_ENV=production

# Frontend (Vite)
VITE_API_BASE_URL=https://your-app.vercel.app/api

# JWT Secret for authentication (Required)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Convex Database
CONVEX_CLOUD_URL=https://your-convex-cloud-url.convex.cloud
HTTP_URL=https://your-convex-http-url.convex.site
CONVEX_DEV_DEPLOY_KEY=dev:your-deployment-key

# Optional: CORS origins
CORS_ORIGIN=https://your-app.vercel.app
